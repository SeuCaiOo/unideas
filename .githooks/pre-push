#!/bin/sh

# ============================================================
# Bloqueia push direto pra main — checa o ref REMOTO sendo
# empurrado (via stdin), não o branch atualmente checked out.
# Isso evita falso positivo ao empurrar tags enquanto HEAD
# está em main.
# ============================================================
while read local_ref local_sha remote_ref remote_sha; do
    if [ "$remote_ref" = "refs/heads/main" ]; then
        echo "❌ Push direto para 'main' não é permitido."
        echo "   Abra um PR a partir de outra branch."
        exit 1
    fi
done

echo "🔨 Validando compilação antes do push..."
./gradlew compileDebugKotlin -x processDebugGoogleServices --daemon --quiet

if [ $? -ne 0 ]; then
    echo "❌ Build falhou! Corrija os erros antes de fazer push."
    exit 1
fi

echo "✅ Build OK."

echo "🔍 Rodando Detekt em todo o projeto..."
./gradlew detekt --daemon

if [ $? -ne 0 ]; then
    echo "❌ Detekt encontrou erros. Corrija antes de fazer push."
    exit 1
fi

echo "✅ Detekt OK."
exit 0
