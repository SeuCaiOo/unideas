#!/bin/sh

# ============================================================
# Bloqueia push pra main a partir de outra branch (ex: feature
# tentando `git push origin HEAD:main`) — não bloqueia mudanças
# pontuais commitadas direto em main, nem pushes de tags. Checa
# o ref REMOTO sendo empurrado (via stdin) contra o branch local
# atual, não só o nome do ref.
# ============================================================
current_branch=$(git symbolic-ref --short HEAD 2>/dev/null)

while read local_ref local_sha remote_ref remote_sha; do
    if [ "$remote_ref" = "refs/heads/main" ] && [ "$current_branch" != "main" ]; then
        echo "❌ Push para 'main' a partir da branch '$current_branch' não é permitido."
        echo "   Abra um PR a partir dessa branch em vez disso."
        exit 1
    fi
done

echo "🔨 Validando compilação antes do push..."
./gradlew compileDebugKotlin -x processDebugGoogleServices --daemon --quiet

if [ $? -ne 0 ]; then
    echo "❌ Build falhou! Corrija os erros antes de fazer push."
    exit 1
fi

echo "✅ Build OK."

echo "🔍 Rodando Detekt em todo o projeto..."
./gradlew detekt --daemon

if [ $? -ne 0 ]; then
    echo "❌ Detekt encontrou erros. Corrija antes de fazer push."
    exit 1
fi

echo "✅ Detekt OK."
exit 0
